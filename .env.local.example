# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: for server-side admin operations
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL — used for sitemap, canonical URLs, robots.txt, and JSON-LD
# Change to https://sssgc-houston.org when custom domain is active
NEXT_PUBLIC_SITE_URL=https://sssgc-houston-ui.vercel.app

# Google Calendar API (for Hindu, US, and other holiday calendars)
# Get your key at: https://console.cloud.google.com/apis/credentials
# Enable "Google Calendar API" in your project first
GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key-here

# Google Gemini API (for AI-powered search — embeddings + summaries)
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
